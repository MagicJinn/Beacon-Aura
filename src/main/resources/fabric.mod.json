{
	"schemaVersion": 1,
	"id": "beacon-aura",
	"version": "${version}",
	"name": "Beacon Aura",
	"description": "Improves beacons by allowing you to soak in a beacon's effects with duration stacking over time.",
	"authors": [
		"MagicJinn"
	],
	"contact": {
		"homepage": "https://github.com/MagicJinn/Beacon-Aura",
		"issues": "https://github.com/MagicJinn/Beacon-Aura/issues"
	},
	"license": "MIT",
	"icon": "assets/beacon-aura/icon.png",
	"environment": "*",
	"entrypoints": {
		"main": [
			"magicjinn.beaconaura.BeaconAura"
		],
		"client": [
			"magicjinn.beaconaura.BeaconAuraClient"
		],
		"modmenu": [
			"magicjinn.beaconaura.config.ModMenuIntegration"
		]
	},
	"mixins": [
		"beacon-aura.mixins.json",
		{
			"config": "beacon-aura.client.mixins.json",
			"environment": "client"
		}
	],
	"depends": {
		"fabricloader": ">=0.18.4",
		"minecraft": "~26.1",
		"java": ">=25"
	},
	"suggests": {
		"modmenu": "*",
		"yet_another_config_lib_v3": "*"
	},
	"breaks": {
		"beacon-range-extender": "*",
		"better_beacon_range": "*",
		"no_beacon_particles": "*"
	},
	"custom": {
		"modmenu": {
			"links": {
				"modmenu.discord": "https://discord.gg/bQvtauxXWp",
				"modmenu.source": "https://github.com/MagicJinn/Beacon-Aura"
			}
		}
	}
}